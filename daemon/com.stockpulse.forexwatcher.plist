<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.stockpulse.forexwatcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/rajneeshmishra/Downloads/stock-pulse/daemon/forex_watcher.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/rajneeshmishra/Downloads/stock-pulse</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <!-- Start on load, restart on failure (not on clean exit) -->
    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- Minimum 10 sec between restart attempts if daemon crashes -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Only run when the user is logged in (GUI session) -->
    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>/Users/rajneeshmishra/Downloads/stock-pulse/logs/forex_watcher.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/rajneeshmishra/Downloads/stock-pulse/logs/forex_watcher.err.log</string>
</dict>
</plist>
